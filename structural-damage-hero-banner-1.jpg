      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much does a general contractor cost in Reno?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "General contractors in Reno typically charge 10-20% of total project cost or $50-$150 per hour. Project minimums start at $25,000 for remodeling and $75,000 for ADU construction. BRE Builders provides free estimates within 24 hours."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need a licensed contractor in Nevada?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, Nevada law requires a licensed contractor for any project over $1,000 including labor and materials. BRE Builders is licensed in Nevada (#0085999) and California (#1009219)."
          }
        },
        {
          "@type": "Question",
          "name": "How long does an ADU take to build in Reno?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ADU construction in Reno typically takes 3-6 months from permit to completion. This includes 4-6 weeks for permits and design, 8-12 weeks for construction, and 2-3 weeks for final inspections."
          }
        }
      ]
    },

